#include <stdio.h>

struct Jogador {
    float pos_x;
    int pontuacao;
    int tem_pulo_duplo;
};

int main() {
    struct Jogador heroi;
    
    heroi.pos_x = 50.0;
    heroi.pontuacao = 0;
    heroi.tem_pulo_duplo = 0;
    
    printf("Inicio da fase! Posicao X: %.1f, Pontos: %d, Pulo Duplo: %s\n",
           heroi.pos_x, heroi.pontuacao, heroi.tem_pulo_duplo ? "Sim" : "Nao");
    
    // Coletar Moeda
    heroi.pontuacao = heroi.pontuacao + 10;
    
    // Coletar Power-up
    heroi.tem_pulo_duplo = 1;
    
    printf("Itens coletados! Posicao X: %.1f, Pontos: %d, Pulo Duplo: %s\n",
           heroi.pos_x, heroi.pontuacao, heroi.tem_pulo_duplo ? "Sim" : "Nao");
    
    return 0;
}
