#include <stdio.h>

int main() {
  
    float coordenada_x;

    
    float *ponteiro_x;

    ponteiro_x = &coordenada_x;

    printf("Digite a coordenada X do portal: ");
    scanf("%f", ponteiro_x);  // usando o ponteiro diretamente

    printf("Posicao do portal no eixo X: %f\n", coordenada_x);

    printf("Endereco do portal para teletransporte: %p\n", (void*)ponteiro_x);

    return 0;
}
